---
import { Image } from 'astro:assets';
import { site } from '@/config/site';
import { globalNav, socialLinks } from '@/config/navigation';
import xIcon from '@/assets/images/x.png';
---

<footer class="footer">
  <div class="footer__main">
    <nav class="footer__nav">
      {
        globalNav.map((item) => (
          <a class="footer__nav-link" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="footer__links">
      {
        socialLinks.map((item) => (
          <a
            class="footer__link"
            href={item.href}
            target="_blank"
            rel="noopener"
            aria-label={item.label}
          >
            <Image class="footer__icon" src={xIcon} alt={item.label} widths={[36, 72]} sizes="18px" />
          </a>
        ))
      }
    </div>
  </div>

  <div class="footer__bottom">
    <span class="footer__copyright">{site.copyright}</span>
  </div>
</footer>

<style lang="scss">
  @use 'foundation' as *;

  .footer {
    margin: 0 auto;
    padding: clamp(48px, 7vw, 72px) clamp(24px, 6vw, 80px) 30px;
    border-top: 1px solid $line;

    // 罫線の上：内部リンク＋Xアイコン
    &__main {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 32px;
      padding-bottom: clamp(32px, 5vw, 48px);

      @include sp-view {
        flex-direction: column;
        gap: 28px;
      }
    }

    &__nav {
      display: flex;
      flex-wrap: wrap;
      gap: 30px;

      @include sp-view {
        flex-direction: column;
        gap: 20px;
      }
    }

    &__nav-link {
      @include font-en;
      @include link-text-hover;

      font-size: 12.5px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      white-space: nowrap;
      color: $sub;
    }

    &__bottom {
      padding-top: clamp(24px, 4vw, 32px);
      border-top: 1px solid $line;
    }

    &__links {
      display: flex;
      gap: 24px;
    }

    &__link {
      display: inline-flex;
      opacity: 0.85;
      transition: opacity 0.3s ease;

      &:hover {
        opacity: 1;
      }
    }

    &__icon {
      width: 18px;
      height: 18px;
      object-fit: contain;
    }

    &__copyright {
      font-size: 11px;
      letter-spacing: 0.12em;
      color: $muted;
    }
  }
</style>
