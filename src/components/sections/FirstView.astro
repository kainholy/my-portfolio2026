---
import { topPage } from '@/data';
import FirstViewImage from '@/assets/images/first-view.jpeg';
import { Image } from 'astro:assets';

const { firstView } = topPage;
---

<section id="top" class="first-view">
  <p class="first-view__eyebrow" data-reveal>{firstView.eyebrow}</p>
  <h1 class="first-view__heading" data-reveal>
    {
      firstView.heading.map((line, index) => (
        <Fragment>
          {index > 0 && <br />}
          {line}
        </Fragment>
      ))
    }
  </h1>
  <p class="first-view__lead" data-reveal>
    {
      firstView.lead.map((line, index) => (
        <Fragment>
          {index > 0 && <br class="first-view__lead-br" />}
          {line}
        </Fragment>
      ))
    }
  </p>
</section>

<div class="first-view__hero" data-reveal>
  <Image
    class="first-view__hero-image"
    src={FirstViewImage}
    alt=""
    format="webp"
    widths={[768, 1280, 1920, 2560]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
</div>

