<style lang="scss">
  @use 'foundation' as *;

  .first-view {
    margin: 0 auto;
    padding: clamp(90px, 13vw, 150px) clamp(24px, 6vw, 80px) clamp(48px, 7vw, 80px);

    &__eyebrow {
      @include font-en;

      margin: 0 0 36px;
      font-size: 13px;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: $accent;

      @include sp-view {
        margin-bottom: 24px;
      }
    }

    &__heading {
      @include heading-fv;

      margin: 0;

      @include sp-view {
        font-size: 30px;
        line-height: 1.6;
      }
    }

    &__lead {
      margin: 18px 0 0;
      max-width: 56ch;
      font-size: 15px;
      line-height: 1.95;
      letter-spacing: 0.08em;
      color: $sub;

      @include sp-view {
        margin-top: 18px;
        font-size: 13px;
      }
    }

    &__lead-br {
      @include sp-view {
        display: none;
      }
    }

    &__hero {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      aspect-ratio: 21 / 9;
      background: repeating-linear-gradient(
        135deg,
        $placeholder,
        $placeholder 9px,
        $panel 9px,
        $panel 18px
      );
      border-top: 1px solid $line;
      border-bottom: 1px solid $line;

      @include sp-view {
        aspect-ratio: 16 / 9;
      }
    }

    &__hero-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    &__hero-placeholder {
      @include font-mono;

      font-size: 11px;
      line-height: 1;
      letter-spacing: 0.14em;
      color: $muted;
    }
  }
</style>
